<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title><%= typeof title !== 'undefined' ? title : 'Bioinformatics Portfolio' %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Bioinformatics freelancer specializing in microbiome analysis, metagenomics workflows, eDNA studies, HPC, and data visualization.' %>">
  <meta name="keywords" content="<%= typeof metaKeywords !== 'undefined' ? metaKeywords : 'bioinformatics, microbiome, metagenomics, eDNA, data science, HPC, Slurm, Conda' %>">

  <!-- Favicons -->
  <link href="/assets/img/favicon.png" rel="icon">
  <link href="/assets/img/apple-touch-icon.png" rel="apple-touch-icon">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Raleway:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

  <!-- Vendor CSS Files -->
  <link href="/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="/assets/vendor/aos/aos.css" rel="stylesheet">
  <link href="/assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">
  <link href="/assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">

  <!-- Main CSS File -->
  <link href="/assets/css/main.css" rel="stylesheet">

  <style>
    .blog-page .main,
    .blog-details-page .main,
    .services-page .main,
    .service-details-page .main {
      background:
        radial-gradient(circle at top left, rgba(56, 189, 248, 0.12), transparent 32%),
        radial-gradient(circle at top right, rgba(16, 185, 129, 0.12), transparent 28%),
        linear-gradient(180deg, #0b1220 0%, #111827 100%);
      color: #e5eefb;
    }

    .blog-page .section-title h2,
    .blog-details-page .section-title h2,
    .services-page .section-title h2,
    .service-details-page .section-title h2,
    .blog-page .portfolio-info h4,
    .blog-details-page .blog-article-header h1,
    .blog-details-page .blog-article-body h2,
    .blog-details-page .blog-article-body h3,
    .blog-details-page .blog-key-takeaways h3,
    .blog-details-page .blog-cta h3,
    .services-page .service-content h3,
    .service-details-page .service-detail-header h1,
    .service-details-page .service-includes h3,
    .service-details-page .pricing-section h2,
    .service-details-page .service-faq-section h2,
    .service-details-page .pricing-card h3 {
      color: #f8fbff;
    }

    .blog-page .section-title p,
    .blog-details-page .section-title p,
    .services-page .section-title p,
    .service-details-page .section-title p,
    .blog-details-page .blog-article-body p,
    .blog-details-page .blog-article-subtitle,
    .blog-details-page .blog-cta p,
    .blog-page .portfolio-info p,
    .services-page .service-content p,
    .service-details-page .service-detail-excerpt,
    .service-details-page .service-detail-intro,
    .service-details-page .pricing-description,
    .service-details-page .accordion-body p {
      color: rgba(229, 238, 251, 0.84);
    }

    .blog-page .portfolio-filters li {
      color: #e5eefb;
      border-color: rgba(229, 238, 251, 0.1);
      background: rgba(255, 255, 255, 0.04);
      transition: all 0.22s ease;
    }

    .blog-page .portfolio-filters li.filter-active,
    .blog-page .portfolio-filters li:hover {
      background: rgba(56, 189, 248, 0.16);
      color: #ffffff;
      border-color: rgba(56, 189, 248, 0.36);
    }

    .blog-page .section,
    .blog-details-page .section,
    .services-page .section,
    .service-details-page .section {
      padding-top: 88px;
      padding-bottom: 88px;
    }

    .service-card-link {
      display: block;
      height: 100%;
      color: inherit;
      text-decoration: none;
      cursor: pointer;
    }

    .service-card-link:hover {
      color: inherit;
      text-decoration: none;
    }

    .service-card-clean {
      height: 100%;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(9, 15, 28, 0.72);
      backdrop-filter: blur(12px);
      transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
    }

    .service-card-link:hover .service-card-clean {
      transform: translateY(-4px);
      box-shadow: 0 24px 48px rgba(0, 0, 0, 0.18);
      border-color: rgba(255, 255, 255, 0.16);
    }

    .service-card-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 18px;
    }

    .service-category-badge {
      display: inline-flex;
      align-items: center;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(56, 189, 248, 0.14);
      border: 1px solid rgba(56, 189, 248, 0.24);
      font-size: 0.88rem;
      line-height: 1;
      color: #f8fbff;
    }

    .service-starting-price {
      font-size: 0.95rem;
      color: rgba(229, 238, 251, 0.8);
    }

    .service-link-static {
      pointer-events: none;
    }

    .service-card-footer {
      margin-top: 20px;
    }

    .service-detail-shell {
      max-width: 1140px;
      margin: 0 auto;
    }

    .service-detail-header {
      max-width: 840px;
      margin-bottom: 36px;
    }

    .service-detail-header h1 {
      margin: 18px 0;
      line-height: 1.14;
    }

    .service-detail-excerpt,
    .service-detail-intro {
      font-size: 1.05rem;
      line-height: 1.85;
      margin-bottom: 14px;
    }

    .service-includes,
    .pricing-section,
    .service-faq-section {
      margin-top: 56px;
    }

    .service-include-card {
      display: flex;
      align-items: center;
      gap: 12px;
      height: 100%;
      padding: 18px 20px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .service-include-card i {
      color: #38bdf8;
      font-size: 1.15rem;
    }

    .pricing-card {
      position: relative;
      display: flex;
      flex-direction: column;
      height: 100%;
      padding: 32px 24px 24px;
      border-radius: 22px;
      background: rgba(9, 15, 28, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 18px 36px rgba(0, 0, 0, 0.14);
      transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
    }

    .pricing-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 22px 42px rgba(0, 0, 0, 0.2);
      border-color: rgba(255, 255, 255, 0.16);
    }

    .pricing-card-featured {
      border-color: rgba(56, 189, 248, 0.5);
      box-shadow: 0 24px 56px rgba(56, 189, 248, 0.14);
    }

    .pricing-badge {
      position: absolute;
      top: 16px;
      right: 16px;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(16, 185, 129, 0.18);
      border: 1px solid rgba(16, 185, 129, 0.32);
      font-size: 0.78rem;
      color: #f8fbff;
    }

    .pricing-card-head {
      margin-bottom: 18px;
    }

    .pricing-price {
      font-size: 2.4rem;
      font-weight: 700;
      color: #f8fbff;
      line-height: 1.2;
      margin-bottom: 10px;
      letter-spacing: -0.03em;
    }

    .pricing-delivery {
      color: rgba(229, 238, 251, 0.72);
      font-size: 0.92rem;
    }

    .pricing-description {
      line-height: 1.75;
      min-height: 104px;
      margin-bottom: 8px;
    }

    .pricing-feature-list {
      list-style: none;
      padding: 0;
      margin: 22px 0 28px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .pricing-feature-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      color: rgba(229, 238, 251, 0.86);
      line-height: 1.6;
    }

    .pricing-feature-list i {
      color: #10b981;
      margin-top: 2px;
    }

    .pricing-select-btn {
      width: 100%;
      margin-top: auto;
      align-self: stretch;
    }

    .service-faq-section .project-accordion {
      max-width: 920px;
    }

    .service-faq-section .accordion-item {
      margin-bottom: 14px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 18px;
      overflow: hidden;
      background: rgba(9, 15, 28, 0.72);
      box-shadow: 0 14px 28px rgba(0, 0, 0, 0.12);
    }

    .service-faq-section .accordion-button {
      background: rgba(255, 255, 255, 0.03);
      color: #f8fbff;
      padding: 22px 24px;
      font-weight: 600;
      line-height: 1.55;
      box-shadow: none;
    }

    .service-faq-section .accordion-button:not(.collapsed) {
      background: rgba(56, 189, 248, 0.08);
      color: #ffffff;
      box-shadow: none;
    }

    .service-faq-section .accordion-button:focus {
      box-shadow: none;
    }

    .service-faq-section .accordion-button::after {
      filter: invert(1);
      opacity: 0.8;
    }

    .service-faq-section .accordion-body {
      background: rgba(255, 255, 255, 0.02);
      padding: 22px 24px 24px;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .service-faq-section .accordion-body p {
      margin: 0;
      line-height: 1.8;
    }

    .contact-choice-modal .modal-content {
      background: #0f172a;
      color: #e5eefb;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
    }

    .contact-choice-modal .modal-header,
    .contact-choice-modal .modal-footer {
      border-color: rgba(255, 255, 255, 0.08);
    }

    .contact-choice-modal .btn-close {
      filter: invert(1);
    }

    .contact-choice-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
      margin-top: 10px;
    }

    .contact-choice-btn {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      min-height: 140px;
      padding: 22px;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      text-decoration: none;
      transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
    }

    .contact-choice-btn:hover {
      transform: translateY(-4px);
      text-decoration: none;
    }

    .contact-choice-btn i {
      font-size: 1.6rem;
    }

    .contact-choice-btn strong {
      font-size: 1.05rem;
      color: #ffffff;
    }

    .contact-choice-btn span {
      color: rgba(229, 238, 251, 0.82);
      line-height: 1.65;
    }

    .contact-choice-whatsapp {
      background: linear-gradient(180deg, rgba(37, 211, 102, 0.18), rgba(37, 211, 102, 0.1));
      border-color: rgba(37, 211, 102, 0.34);
      color: #ffffff;
    }

    .contact-choice-whatsapp:hover {
      box-shadow: 0 18px 36px rgba(37, 211, 102, 0.16);
      color: #ffffff;
    }

    .contact-choice-email {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.03));
      border-color: rgba(255, 255, 255, 0.14);
      color: #ffffff;
    }

    .contact-choice-email:hover {
      box-shadow: 0 18px 36px rgba(0, 0, 0, 0.18);
      color: #ffffff;
    }

    .blog-card-link {
      display: block;
      height: 100%;
      color: inherit;
      text-decoration: none;
      cursor: pointer;
    }

    .blog-card-link:hover {
      color: inherit;
      text-decoration: none;
    }

    .blog-card {
      height: 100%;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(9, 15, 28, 0.72);
      backdrop-filter: blur(12px);
      transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
    }

    .blog-card-link:hover .blog-card {
      transform: scale(1.02);
      box-shadow: 0 24px 48px rgba(0, 0, 0, 0.18);
      border-color: rgba(255, 255, 255, 0.16);
    }

    .blog-card .portfolio-img {
      aspect-ratio: 16 / 10;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.04);
    }

    .blog-card .portfolio-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: none;
    }

    .blog-card .portfolio-info {
      display: flex;
      flex-direction: column;
      gap: 14px;
      padding: 28px;
    }

    .blog-card .portfolio-info h4 {
      margin: 0;
    }

    .blog-card .portfolio-info p {
      margin: 0;
    }

    .blog-card-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 0.95rem;
      opacity: 0.82;
    }

    .blog-card-excerpt {
      line-height: 1.75;
      opacity: 0.9;
    }

    .blog-card-footer {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: auto;
    }

    .blog-badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .blog-badge,
    .blog-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.09);
      font-size: 0.88rem;
      line-height: 1;
    }

    .blog-card-readmore {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
    }

    .blog-article-shell {
      max-width: 860px;
      margin: 0 auto;
    }

    .blog-back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 28px;
      text-decoration: none;
    }

    .blog-back-link:hover {
      text-decoration: none;
    }

    .blog-article-header {
      margin-bottom: 28px;
    }

    .blog-article-header h1 {
      margin-bottom: 18px;
      line-height: 1.16;
    }

    .blog-article-subtitle {
      font-size: 1.12rem;
      line-height: 1.8;
      opacity: 0.9;
      margin-bottom: 22px;
    }

    .blog-meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 18px;
    }

    .blog-meta-item {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.08);
      font-size: 0.92rem;
    }

    .blog-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .blog-featured-image {
      margin: 30px 0 42px;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 24px 50px rgba(0, 0, 0, 0.18);
    }

    .blog-featured-image img {
      width: 100%;
      height: auto;
      display: block;
    }

    .blog-article-body {
      line-height: 1.9;
      font-size: 1.02rem;
    }

    .blog-article-body h2,
    .blog-article-body h3 {
      margin-top: 40px;
      margin-bottom: 16px;
      line-height: 1.3;
    }

    .blog-article-body p {
      margin-bottom: 18px;
    }

    .blog-key-takeaways {
      margin-top: 42px;
      padding: 28px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .blog-key-takeaways ul {
      margin: 18px 0 0;
      padding-left: 1.2rem;
    }

    .blog-key-takeaways li {
      margin-bottom: 10px;
    }

    .blog-cta {
      margin-top: 36px;
      padding: 28px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .blog-cta p {
      margin-bottom: 18px;
      line-height: 1.8;
    }

    .blog-cta-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }

    .whatsapp-float {
      position: fixed;
      right: 24px;
      bottom: 24px;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: #25d366;
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 12px 30px rgba(37, 211, 102, 0.35);
      z-index: 9999;
      transform: translateY(18px);
      opacity: 0;
      animation: floating-action-in 0.45s ease forwards;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    .whatsapp-float:hover {
      color: #ffffff;
      background: #1ebe5d;
      transform: translateY(-2px);
      box-shadow: 0 16px 34px rgba(37, 211, 102, 0.45);
    }

    .whatsapp-float i {
      font-size: 1.7rem;
      line-height: 1;
    }

    .scroll-top {
      bottom: 92px;
      transform: translateY(12px);
      opacity: 0;
      transition: all 0.3s ease;
    }

    .scroll-top.active {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes floating-action-in {
      from {
        opacity: 0;
        transform: translateY(18px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 576px) {
      .blog-card .portfolio-info,
      .blog-key-takeaways,
      .blog-cta,
      .pricing-card {
        padding: 22px;
      }

      .blog-page .section,
      .blog-details-page .section,
      .services-page .section,
      .service-details-page .section {
        padding-top: 72px;
        padding-bottom: 72px;
      }

      .contact-choice-actions {
        grid-template-columns: 1fr;
      }

      .whatsapp-float {
        right: 16px;
        bottom: 16px;
        width: 52px;
        height: 52px;
      }

      .scroll-top {
        bottom: 82px;
      }
    }
  </style>
</head>
