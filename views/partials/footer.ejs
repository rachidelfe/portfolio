<script src="/assets/vendor/purecounter/purecounter_vanilla.js"></script>
<script src="/assets/vendor/swiper/swiper-bundle.min.js"></script>
<script src="/assets/vendor/imagesloaded/imagesloaded.pkgd.min.js"></script>
<script src="/assets/vendor/isotope-layout/isotope.pkgd.min.js"></script>
<script src="/assets/vendor/glightbox/js/glightbox.min.js"></script>

<!-- Main JS File -->
<script src="/assets/js/main.js"></script>
<script>
  (function() {
    const modalElement = document.getElementById('contactChoiceModal');
    const whatsappButton = document.getElementById('contactChoiceWhatsapp');
    const emailButton = document.getElementById('contactChoiceEmail');
    const modalText = document.getElementById('contactChoiceModalText');

    if (!modalElement || !whatsappButton || !emailButton || typeof bootstrap === 'undefined') {
      return;
    }

    const contactChoiceModal = new bootstrap.Modal(modalElement);

    document.querySelectorAll('[data-contact-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault();

        const service = trigger.getAttribute('data-service') || 'Bioinformatics Service';
        const plan = trigger.getAttribute('data-plan') || 'General Inquiry';
        const whatsappMessage = trigger.getAttribute('data-whatsapp-message') || `Hello, I am interested in ${service} - ${plan}.`;
        const emailSubject = trigger.getAttribute('data-email-subject') || `Service Request: ${service} - ${plan}`;

        whatsappButton.href = `https://wa.me/YOUR_NUMBER?text=${encodeURIComponent(whatsappMessage)}`;
        emailButton.href = `/contact?subject=${encodeURIComponent(emailSubject)}`;
        modalText.textContent = `Choose how you would like to continue for ${service}${plan ? ` - ${plan}` : ''}.`;

        contactChoiceModal.show();
      });
    });
  })();
</script>
</body>
