<%- include('partials/head', {title: title}) %>
<body class="<%= bodyClass || '' %>">
  <%- include('partials/header', {bodyClass: bodyClass}) %>

  <main class="main">

    <!-- About Section -->
    <section id="about" class="about section">

      <!-- Section Title -->
      <div class="container section-title" data-aos="fade-up">
        <h2>About</h2>
        <p>Bioinformatics freelancer with a background in biology and computational analysis, supporting researchers with microbiome, metagenomics, and eDNA projects.</p>
      </div><!-- End Section Title -->

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <!-- Intro + Photo -->
        <div class="row align-items-center justify-content-between gy-5 mb-5">
          <div class="col-lg-7" data-aos="fade-right" data-aos-delay="150">
            <div class="intro-content">
              <span class="eyebrow">Background</span>
              <h2 class="headline">I work at the intersection of biology, bioinformatics, and data science.</h2>
              <p class="lead">
                My work focuses on helping research teams analyze complex biological datasets with practical, reproducible workflows. I support projects involving human, environmental, and plant microbiomes, metagenomics, and eDNA studies.
              </p>
              <p>
                Using Python, R, and HPC environments, I build pipelines that move cleanly from raw sequencing data to interpretable results. I value clear reporting, efficient collaboration, and scientific outputs that labs can reuse for manuscripts, grants, and ongoing analysis.
              </p>

              <div class="cta-group">
                <a href="/services" class="btn-ghost">
                  View Services <i class="bi bi-arrow-up-right"></i>
                </a>
                <a href="/resume" class="link-underline">
                  Review Resume <i class="bi bi-file-earmark-text"></i>
                </a>
              </div>
            </div>
          </div>

          <div class="col-lg-5" data-aos="zoom-in" data-aos-delay="250">
            <figure class="profile-figure text-center text-lg-end">
              <img src="/assets/img/profile/profile-square-11.webp" alt="Portrait of Rachid Elfermi" class="img-fluid profile-photo">
            </figure>
          </div>
        </div>
        <!-- End Intro + Photo -->

        <!-- Skills Grid -->
        <div class="mb-5">
          <div class="row g-4">
            <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="120">
              <div class="skill-item">
                <i class="bi bi-diagram-3"></i>
                <h3>Microbiome Studies</h3>
                <p>Human, environmental, and plant community profiling.</p>
              </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="180">
              <div class="skill-item">
                <i class="bi bi-code-slash"></i>
                <h3>Metagenomics</h3>
                <p>Shotgun workflows, annotation, and comparative analysis.</p>
              </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="240">
              <div class="skill-item">
                <i class="bi bi-water"></i>
                <h3>eDNA Analysis</h3>
                <p>Biodiversity monitoring pipelines for environmental samples.</p>
              </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="300">
              <div class="skill-item">
                <i class="bi bi-cpu"></i>
                <h3>HPC Workflows</h3>
                <p>Python, R, Slurm, Conda, and reproducible pipeline design.</p>
              </div>
            </div>
          </div>
        </div>
        <!-- End Skills Grid -->

        <!-- Journey Timeline -->
        <div class="mb-5">
          <div class="row g-4">
            <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="120">
              <article class="timeline-item">
                <span class="dot"></span>
                <time>2016</time>
                <h4>Biology Foundation</h4>
                <p>Built a strong base in molecular biology, genetics, and ecology.</p>
              </article>
            </div>
            <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="180">
              <article class="timeline-item">
                <span class="dot"></span>
                <time>2019</time>
                <h4>Bioinformatics Training</h4>
                <p>Shifted into sequence analysis, statistics, and computational workflows.</p>
              </article>
            </div>
            <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="240">
              <article class="timeline-item">
                <span class="dot"></span>
                <time>2022</time>
                <h4>Research Pipeline Work</h4>
                <p>Developed reproducible analysis systems for genomics and metagenomics studies.</p>
              </article>
            </div>
            <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
              <article class="timeline-item">
                <span class="dot"></span>
                <time>2026</time>
                <h4>Freelance Collaboration</h4>
                <p>Supporting labs and research teams with flexible project-based analysis.</p>
              </article>
            </div>
          </div>
        </div>
        <!-- End Journey Timeline -->

        <!-- Quote -->
        <blockquote class="personal-quote text-center mb-5" data-aos="fade-down" data-aos-delay="200">
          <p>"Good bioinformatics should be reproducible, understandable, and useful to the scientists making decisions from the data."</p>
        </blockquote>
        <!-- End Quote -->

        <!-- Fun Facts -->
        <div class="row g-3 justify-content-center">
          <div class="col-6 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="120">
            <div class="fact-pill">
              <i class="bi bi-people"></i>
              <span>Lab Partnerships</span>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="160">
            <div class="fact-pill">
              <i class="bi bi-journal-code"></i>
              <span>Open Workflows</span>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="200">
            <div class="fact-pill">
              <i class="bi bi-hdd-network"></i>
              <span>HPC Ready</span>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="240">
            <div class="fact-pill">
              <i class="bi bi-bar-chart"></i>
              <span>Clear Reporting</span>
            </div>
          </div>
        </div>
        <!-- End Fun Facts -->

      </div>

    </section><!-- /About Section -->

    <!-- Skills Section -->
    <section id="skills" class="skills section">

      <!-- Section Title -->
      <div class="container section-title" data-aos="fade-up">
        <h2>Skills</h2>
        <p>Core technical strengths across bioinformatics analysis, workflow automation, HPC deployment, and scientific communication.</p>
      </div><!-- End Section Title -->

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row g-4 skills-animation">

          <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
            <div class="skill-box">
              <h3>Microbiome &amp; Metagenomics</h3>
              <p>Community profiling, shotgun analysis, and ecological interpretation.</p>
              <span class="text-end d-block">95%</span>
              <div class="progress">
                <div class="progress-bar" role="progressbar" aria-valuenow="95" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
            </div>
          </div>

          <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
            <div class="skill-box">
              <h3>Python &amp; R</h3>
              <p>Data cleaning, statistical analysis, plotting, and automation.</p>
              <span class="text-end d-block">92%</span>
              <div class="progress">
                <div class="progress-bar" role="progressbar" aria-valuenow="92" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
            </div>
          </div>

          <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
            <div class="skill-box">
              <h3>HPC &amp; Workflow Automation</h3>
              <p>Slurm, Conda, reproducible environments, and scalable pipelines.</p>
              <span class="text-end d-block">90%</span>
              <div class="progress">
                <div class="progress-bar" role="progressbar" aria-valuenow="90" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
            </div>
          </div>

          <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="400">
            <div class="skill-box">
              <h3>Visualization &amp; Reporting</h3>
              <p>Figures, dashboards, summaries, and manuscript-ready outputs.</p>
              <span class="text-end d-block">88%</span>
              <div class="progress">
                <div class="progress-bar" role="progressbar" aria-valuenow="88" aria-valuemin="0" aria-valuemax="100">
                </div>
              </div>
            </div>
          </div>

        </div>

      </div>

    </section><!-- /Skills Section -->

    <!-- Stats Section -->
    <section id="stats" class="stats section dark-background">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row align-items-center">
          <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
            <div class="avatars d-flex align-items-center">
              <img src="/assets/img/person/person-m-2.webp" alt="Research collaborator" class="rounded-circle" loading="lazy">
              <img src="/assets/img/person/person-m-3.webp" alt="Research collaborator" class="rounded-circle" loading="lazy">
              <img src="/assets/img/person/person-f-5.webp" alt="Research collaborator" class="rounded-circle" loading="lazy">
              <img src="/assets/img/person/person-m-5.webp" alt="Research collaborator" class="rounded-circle" loading="lazy">
            </div>
          </div>

          <div class="col-lg-8">
            <div class="row counters">
              <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                <h2><span data-purecounter-start="0" data-purecounter-end="18" data-purecounter-duration="1" class="purecounter"></span>+</h2>
                <p>Research Projects Supported</p>
              </div>

              <div class="col-md-4" data-aos="fade-up" data-aos-delay="400">
                <h2><span data-purecounter-start="0" data-purecounter-end="9" data-purecounter-duration="1" class="purecounter"></span>+</h2>
                <p>Collaborating Labs</p>
              </div>

              <div class="col-md-4" data-aos="fade-up" data-aos-delay="500">
                <h2><span data-purecounter-start="0" data-purecounter-end="6" data-purecounter-duration="1" class="purecounter"></span>+</h2>
                <p>Production Pipelines Delivered</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </section><!-- /Stats Section -->
  </main>

  <%- include('partials/footer') %>
